&FORCE_EVAL
  &DFT
    WFN_RESTART_FILE_NAME .wfn
    &QS
      METHOD xTB
      &xTB
        DO_EWALD  T
        CHECK_ATOMIC_CHARGES  F
        COULOMB_INTERACTION T
        &PARAMETER
          DISPERSION_PARAMETER_FILE  dftd3.dat
          PARAM_FILE_NAME xTB_parameters
        &END PARAMETER
      &END
      &DISTRIBUTION
        BASIC_OPTIMIZATION .FALSE.
        BASIC_SPATIAL_OPTIMIZATION .TRUE.
      &END
    &END QS
    ! Only for cube visualization
    &MGRID
      CUTOFF 200
    &END
    &POISSON
      POISSON_SOLVER PERIODIC !MT
      PERIODIC XYZ !NONE
    &END
    &SCF
      SCF_GUESS RESTART !MOPAC
      EPS_SCF 1.e-6
      ADDED_MOS 50
!      &OUTER_SCF
!         MAX_SCF  30
!         EPS_SCF 1.e-6
!      &END
      MAX_SCF 50 
    &END SCF
    &PRINT
      &MO ON
        FILENAME CsPbBr3
        EIGENVECTORS F
        EIGENVALUES F
        NDIGITS 8
      &END
      &PDOS 
        APPEND T
        COMPONENTS T
        FILENAME c3n4_1x1
      &END
      &MO_MOLDEN ON
        FILENAME    
        NDIGITS 8
        GTO_KIND SPHERICAL
      &END 
      &MO_CUBES
        NHOMO 1
        NLUMO 1
        STRIDE 3 3 3
        WRITE_CUBE T
      &END
    &END
  &END DFT
  &SUBSYS
    &CELL
      A         8.3231830000         0.0000000000         0.0000000000
      B         0.0000000000         8.2646980000         0.0000000000
      C         0.0000000000         0.0000000000        11.8958500000
      PERIODIC XYZ
    &END CELL
    &TOPOLOGY
      COORD_FILE_NAME coord.xyz 
      COORD_FILE_FORMAT XYZ
    &END
   &END SUBSYS
&END FORCE_EVAL
&GLOBAL
  PROJECT_NAME CsPbBr3
  RUN_TYPE ENERGY
  PRINT_LEVEL LOW
&END GLOBAL

